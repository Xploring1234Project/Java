The Multi-Exception Scenario
In this example, we manually throw exceptions if the user data is invalid, and the method throws a checked exception to signal that a file operation might fail.
import java.io.IOException;

public class RegistrationSystem {

    // 'throws' indicates this method might fail with an IOException
    public static void registerUser(String username, int age) throws IOException {
        
        // 1. Using 'throw' for business logic (Unchecked Exception)
        if (age < 13) {
            throw new ArithmeticException("Underage: Users must be at least 13.");
        }

        // 2. Using 'throw' for data validation (Unchecked Exception)
        if (username == null || username.length() < 3) {
            throw new IllegalArgumentException("Invalid Username: Minimum 3 characters required.");
        }

        // 3. Simulating a 'throw' for a system error (Checked Exception)
        if (username.equals("admin")) {
            throw new IOException("Database Error: 'admin' is a reserved system name.");
        }

        System.out.println("User " + username + " registered successfully!");
    }

    public static void main(String[] args) {
        // Test Case 1: Too young
        try {
            registerUser("jdoe", 10);
        } catch (Exception e) {
            System.out.println("Caught Error: " + e.getMessage());
        }

        // Test Case 2: Bad username
        try {
            registerUser("jo", 20);
        } catch (Exception e) {
            System.out.println("Caught Error: " + e.getMessage());
        }

        // Test Case 3: Reserved name (Checked Exception)
        try {
            registerUser("admin", 25);
        } catch (IOException e) {
            System.out.println("Caught File/DB Error: " + e.getMessage());
        }
    }
}
