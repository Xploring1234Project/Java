Java Code Demonstration
import java.util.*;

public class LinkedListDemo {
    public static void main(String[] args) {
        LinkedList<String> list = new LinkedList<>();

        // 1. Adding Elements
        list.add("A");
        list.add(1, "B");
        list.addAll(Arrays.asList("C", "D"));
        list.addAll(2, Arrays.asList("E", "F"));
        list.addFirst("Start");
        list.addLast("End");
        list.offer("G");
        list.offerFirst("H");
        list.offerLast("I");
        list.push("StackTop");

        // 2. Accessing Elements
        System.out.println(list.get(2));
        System.out.println(list.getFirst());
        System.out.println(list.getLast());
        System.out.println(list.peek());
        System.out.println(list.peekFirst());
        System.out.println(list.peekLast());
        System.out.println(list.element());

        // 3. Updating Elements
        list.set(2, "Updated");

        // 4. Removing Elements
        list.remove();
        list.remove(1);
        list.remove("C");
        list.removeFirst();
        list.removeLast();
        list.removeFirstOccurrence("E");
        list.removeLastOccurrence("F");
        list.removeAll(Arrays.asList("G", "H"));
        list.removeIf(s -> s.startsWith("U"));
        list.poll();
        list.pollFirst();
        list.pollLast();
        list.pop();
        list.retainAll(Arrays.asList("A", "B", "End"));
        list.clear();

        // 5. Searching & Checking
        System.out.println(list.contains("A"));
        System.out.println(list.containsAll(Arrays.asList("A", "B")));
        System.out.println(list.indexOf("A"));
        System.out.println(list.lastIndexOf("B"));
        System.out.println(list.isEmpty());
        System.out.println(list.size());
        System.out.println(list.equals(new LinkedList<>()));
        System.out.println(list.hashCode());

        // 6. Iteration
        list.addAll(Arrays.asList("X", "Y", "Z"));
        Iterator<String> it = list.iterator();
        while (it.hasNext()) System.out.println(it.next());

        ListIterator<String> lit = list.listIterator();
        while (lit.hasNext()) System.out.println(lit.next());

        ListIterator<String> lit2 = list.listIterator(1);
        while (lit2.hasNext()) System.out.println(lit2.next());

        Iterator<String> descIt = list.descendingIterator();
        while (descIt.hasNext()) System.out.println(descIt.next());

        list.forEach(System.out::println);
        Spliterator<String> spl = list.spliterator();
        spl.forEachRemaining(System.out::println);

        // 7. Conversion
        Object[] arr = list.toArray();
        String[] strArr = list.toArray(new String[0]);

        // 8. Queue/Stack
        list.offer("Queue");
        System.out.println(list.poll());
        System.out.println(list.peek());
        System.out.println(list.element());
        list.push("Stack");
        System.out.println(list.pop());

        // 9. Sublist
        List<String> sub = list.subList(0, 1);
        System.out.println(sub);
    }
}
